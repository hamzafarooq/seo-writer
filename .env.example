# SEO Article Writer — Environment Variables
# Copy this file to .env and fill in your keys.
#   cp .env.example .env

# Required: Anthropic API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: SerpAPI key (https://serpapi.com/)
# Enables live SERP research + Google Image search for article images.
# Without it, Claude knowledge is used and Unsplash search links are provided.
SERPAPI_KEY=
